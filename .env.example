# Environment Configuration for BeeBot Backend

# Server Configuration
NODE_ENV=development
PORT=5000

# Database
MONGO_URI=mongodb://localhost:27017/beebot

# JWT Secret (use a strong secret in production)
JWT_SECRET=your_strong_jwt_secret_here

# CORS Origins (comma-separated)
# Development: http://localhost:5173,http://localhost:3000
# Production: https://app.beebot.com,https://dashboard.beebot.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# AI Service
PYTHON_SERVICE_URL=http://localhost:8000

# Example Production Configuration:
# NODE_ENV=production
# ALLOWED_ORIGINS=https://app.beebot.com,https://dashboard.beebot.com
# JWT_SECRET=super_secure_production_secret
